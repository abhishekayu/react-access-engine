{
  "name": "react-access-engine-devtools",
  "version": "0.1.3",
  "description": "DevTools overlay for react-access-engine — inspect RBAC, ABAC, feature flags, A/B experiments, policies, and access decisions in real time. Zero-config debug panel for React.",
  "author": "Abhishek Verma",
  "license": "MIT",
  "homepage": "https://react-access-engine.dev",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/abhishekayu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishekayu/react-access-engine.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/abhishekayu/react-access-engine/issues"
  },
  "keywords": [
    "react",
    "devtools",
    "developer-tools",
    "debug",
    "react-access-engine",
    "access-control",
    "rbac",
    "abac",
    "authorization",
    "permissions",
    "feature-flags",
    "feature-toggles",
    "a/b-testing",
    "ab-testing",
    "experiments",
    "policy-engine",
    "react-devtools",
    "debug-overlay",
    "inspector",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-access-engine": ">=0.1.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-access-engine": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
