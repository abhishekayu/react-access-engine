{
  "name": "react-access-engine-devtools",
  "version": "0.1.0",
  "description": "Development-only devtools overlay for react-access-engine — visualize access decisions, feature flags, policies, and experiments in real time",
  "author": "Abhishek",
  "license": "MIT",
  "homepage": "https://github.com/abhishekayu/react-access-engine#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishekayu/react-access-engine.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/abhishekayu/react-access-engine/issues"
  },
  "keywords": [
    "react",
    "devtools",
    "access-control",
    "rbac",
    "feature-flags",
    "debug",
    "react-access-engine",
    "developer-tools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-access-engine": ">=0.1.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-access-engine": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
