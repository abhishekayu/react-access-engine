{
  "name": "react-access-engine",
  "version": "1.0.0",
  "description": "Unified access control for React & Node.js — RBAC, ABAC, feature flags, A/B experiments, plan gating, policy engine, remote config. Works with Next.js, Express, Fastify. SSR-safe, tree-shakeable, zero dependencies. One hook, one component.",
  "author": "Abhishek Verma",
  "license": "MIT",
  "homepage": "https://react-access-engine.dev",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/abhishekayu"
  },
  "keywords": [
    "react-access-engine",
    "react",
    "nextjs",
    "nodejs",
    "express",
    "access-control",
    "rbac",
    "abac",
    "permissions",
    "authorization",
    "feature-flags",
    "feature-toggles",
    "feature-toggle",
    "a-b-testing",
    "ab-testing",
    "experiments",
    "policy-engine",
    "role-based-access-control",
    "attribute-based-access-control",
    "plan-gating",
    "subscription",
    "remote-config",
    "rollout",
    "middleware",
    "react-hooks",
    "hooks",
    "typescript",
    "access-gate",
    "permission-guard",
    "user-permissions",
    "access-management",
    "tree-shakeable",
    "ssr-safe",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishekayu/react-access-engine.git",
    "directory": "packages/react-access-engine"
  },
  "bugs": {
    "url": "https://github.com/abhishekayu/react-access-engine/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./engines": {
      "import": {
        "types": "./dist/engines/index.d.ts",
        "default": "./dist/engines/index.js"
      },
      "require": {
        "types": "./dist/engines/index.d.cts",
        "default": "./dist/engines/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
